{
  "name": "yekta/wp-sms-monorepo",
  "description": "QA and packaging tooling for the Yekta SMS plugin ecosystem monorepo.",
  "type": "project",
  "license": "proprietary",
  "require": {},
  "require-dev": {
    "php": "^8.1",
    "phpunit/phpunit": "^9.6",
    "phpstan/phpstan": "^1.12",
    "squizlabs/php_codesniffer": "^3.10",
    "wp-coding-standards/wpcs": "^3.1",
    "php-stubs/wordpress-stubs": "^6.8",
    "php-stubs/woocommerce-stubs": "^10.0",
    "dealerdirect/phpcodesniffer-composer-installer": "^1.0"
  },
  "autoload": {
    "psr-4": {
      "YektaSMS\\Core\\": "core/src/",
      "YektaSMS\\Gateway\\SmsIr\\": "geateway/yekta-geateway-smsir/src/",
      "YektaSMS\\Integration\\WooComrce\\": "integration/yekta-integration-woocomrce/src/"
    }
  },
  "autoload-dev": {
    "files": [
      "tests/stubs/wordpress-bootstrap.php"
    ]
  },
  "scripts": {
    "lint": "phpcs",
    "format": "phpcbf",
    "format-check": "phpcs --report=full",
    "stan": "phpstan analyse --memory-limit=1G",
    "test": "phpunit --configuration phpunit.xml.dist",
    "qa": [
      "@lint",
      "@stan",
      "@test"
    ],
    "package": "bash scripts/package-plugins.sh"
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
